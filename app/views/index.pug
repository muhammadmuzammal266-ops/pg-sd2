extends layout

block content
  section.hero
    .hero-left
      h1 Level Up Your Gaming Skills
      p Discover powerful tips, smart strategies, and community advice for your favourite games.
      .hero-buttons
        a.read-more(href="/tips") Explore Tips
        a.btn-secondary(href="/signup") Join Community
    .hero-right.auto-slide(data-theme="home")
      .hero-card
        h3 Trending Today
        p Explore action, racing, survival, sports, and strategy tips in one place.

  section.home-section
    h2.section-heading Popular Categories

    .home-grid
      .home-card.auto-slide(data-theme="action")
        .home-badge Action
        h3 Fast Reflex Tips
        p Improve aim, movement, and reaction timing in high-pressure games.
        a.read-more(href="/tips") View Tips

      .home-card.auto-slide(data-theme="strategy")
        .home-badge Strategy
        h3 Smart Tactical Plays
        p Learn planning, defense, and resource control for strategy-based games.
        a.read-more(href="/tips") View Tips

      .home-card.auto-slide(data-theme="racing")
        .home-badge Racing
        h3 Drive With Control
        p Master braking, cornering, and acceleration for better race performance.
        a.read-more(href="/tips") View Tips

      .home-card.auto-slide(data-theme="survival")
        .home-badge Survival
        h3 Stay Alive Longer
        p Collect smarter, build faster, and manage risk in survival worlds.
        a.read-more(href="/tips") View Tips

  section.feature-strip
    .feature-box
      h3 Share Your Own Tips
      p Create your own posts and help other gamers improve.
    .feature-box
      h3 Save What You Like
      p Bookmark useful tips and return to them anytime.
    .feature-box
      h3 Join The Conversation
      p Comment on posts and interact with other players.