extends layout

block content
  .page-shell
    h1.page-title Search Results
    if query
      p.search-text Results for: "#{query}"

    if data.length > 0
      .card-grid
        each tip in data
          .card.tip-card
            .tip-card-top
              .tip-author
                img.author-avatar(src=tip.profile_image || "/default-avatar.svg", alt="user")
                div
                  h3 #{tip.title}
                  p.small-meta By #{tip.username}
              .tip-menu
                button.menu-btn(type="button") ⋯
                .menu-dropdown
                  a(href=`/tips/${tip.id}`) View Tip
                  if currentUser && currentUser.id === tip.user_id
                    a(href=`/tips/${tip.id}/edit`) Edit Tip
                    form(action=`/tips/${tip.id}/delete`, method="post")
                      button.dropdown-action(type="submit") Delete Tip
                  else if currentUser
                    if savedIds.includes(tip.id)
                      form(action=`/unsave-tip/${tip.id}`, method="post")
                        button.dropdown-action(type="submit") Remove Saved Tip
                    else
                      form(action=`/save-tip/${tip.id}`, method="post")
                        button.dropdown-action(type="submit") Save Tip
                  else
                    a(href="/login") Log in to Save

            p
              strong Game:
              |  #{tip.game_name}
            a.read-more(href=`/tips/${tip.id}`) View Tip
    else
      .info-box
        h2 No matching tips found